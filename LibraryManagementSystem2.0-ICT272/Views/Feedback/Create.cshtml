@model LibraryManagementSystem.Models.Feedback
@{
    ViewData["Title"] = "Write a Review";
    var book = ViewBag.Book as LibraryManagementSystem.Models.Book;
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-7">

            @if (book != null)
            {
                <div class="card mb-4">
                    <div class="card-body">
                        <div class="d-flex gap-3 align-items-center">
                            @if (!string.IsNullOrEmpty(
                                                    book.CoverImagePath))
                            {
                                <img src="@book.CoverImagePath"
                                     style="width:60px; height:80px;
                                                    object-fit:cover;
                                                    border-radius:6px;"
                                     alt="@book.Title" />
                            }
                            else
                            {
                                <div style="width:60px; height:80px;
                                                    background:#e8edf2;
                                                    border-radius:6px;
                                                    display:flex;
                                                    align-items:center;
                                                    justify-content:center;
                                                    font-size:1.5rem;
                                                    color:#8fa3b1;">
                                    <i class="bi bi-book"></i>
                                </div>
                            }
                            <div>
                                <h5 class="fw-bold mb-1">
                                    @book.Title
                                </h5>
                                <p class="text-muted mb-0">
                                    by @book.Author
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-star me-2"></i>
                        Write Your Review
                    </h5>
                </div>
                <div class="card-body p-4">

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">
                            @ViewBag.Error
                        </div>
                    }

                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()

                        <input type="hidden"
                               name="bookId"
                               value="@Model.BookId" />

                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                Your Rating
                                <span class="text-danger">*</span>
                            </label>
                            <div class="d-flex gap-3 mb-1"
                                 id="starContainer">
                                <i class="bi bi-star star-icon"
                                   data-val="1"
                                   style="font-size:2.2rem;
                                          cursor:pointer;
                                          color:#dee2e6;">
                                </i>
                                <i class="bi bi-star star-icon"
                                   data-val="2"
                                   style="font-size:2.2rem;
                                          cursor:pointer;
                                          color:#dee2e6;">
                                </i>
                                <i class="bi bi-star star-icon"
                                   data-val="3"
                                   style="font-size:2.2rem;
                                          cursor:pointer;
                                          color:#dee2e6;">
                                </i>
                                <i class="bi bi-star star-icon"
                                   data-val="4"
                                   style="font-size:2.2rem;
                                          cursor:pointer;
                                          color:#dee2e6;">
                                </i>
                                <i class="bi bi-star star-icon"
                                   data-val="5"
                                   style="font-size:2.2rem;
                                          cursor:pointer;
                                          color:#dee2e6;">
                                </i>
                            </div>
                            <small id="ratingLabel"
                                   class="text-muted">
                                Click a star to rate
                            </small>
                            <input type="hidden"
                                   id="ratingValue"
                                   name="rating"
                                   value="0" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                Your Review
                            </label>
                            <textarea name="comment"
                                      class="form-control"
                                      rows="5"
                                      placeholder="Share your thoughts about this book...">
                            </textarea>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit"
                                    class="btn btn-primary px-4">
                                <i class="bi bi-send me-1"></i>
                                Submit Review
                            </button>
                            <a asp-controller="Books"
                               asp-action="Details"
                               asp-route-id="@Model.BookId"
                               class="btn btn-outline-secondary px-4">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        var labels = ['', 'Poor', 'Fair', 'Good',
                      'Very Good', 'Excellent'];
        var stars = document.querySelectorAll('.star-icon');
        var ratingInput = document.getElementById('ratingValue');
        var ratingLabel = document.getElementById('ratingLabel');
        var currentRating = 0;

        function paintStars(upTo) {
            stars.forEach(function(s) {
                var val = parseInt(s.getAttribute('data-val'));
                if (val <= upTo) {
                    s.className = 'bi bi-star-fill star-icon';
                    s.style.color = '#f59e0b';
                } else {
                    s.className = 'bi bi-star star-icon';
                    s.style.color = '#dee2e6';
                }
            });
        }

        stars.forEach(function(star) {
            star.addEventListener('click', function() {
                currentRating = parseInt(
                    this.getAttribute('data-val'));
                ratingInput.value = currentRating;
                ratingLabel.textContent = labels[currentRating];
                paintStars(currentRating);
            });

            star.addEventListener('mouseover', function() {
                var val = parseInt(
                    this.getAttribute('data-val'));
                paintStars(val);
            });

            star.addEventListener('mouseout', function() {
                paintStars(currentRating);
            });
        });
    </script>
}