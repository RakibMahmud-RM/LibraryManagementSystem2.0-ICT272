@model LibraryManagementSystem.Models.Feedback
@{
    ViewData["Title"] = "Write a Review";
    var book = ViewBag.Book as LibraryManagementSystem.Models.Book;
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-7">

            <!-- Book Info Card -->
            @if (book != null)
            {
                <div class="card mb-4">
                    <div class="card-body">
                        <div class="d-flex gap-3 align-items-center">
                            @if (!string.IsNullOrEmpty(book.CoverImagePath))
                            {
                                <img src="@book.CoverImagePath"
                                     style="width:60px; height:80px;
                                                    object-fit:cover;
                                                    border-radius:6px;"
                                     alt="@book.Title" />
                            }
                            else
                            {
                                <div style="width:60px; height:80px;
                                                    background:#e8edf2;
                                                    border-radius:6px;
                                                    display:flex;
                                                    align-items:center;
                                                    justify-content:center;
                                                    font-size:1.5rem;
                                                    color:#8fa3b1;">
                                    <i class="bi bi-book"></i>
                                </div>
                            }
                            <div>
                                <h5 class="fw-bold mb-1">@book.Title</h5>
                                <p class="text-muted mb-0">by @book.Author</p>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <!-- Review Form -->
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-star me-2"></i>
                        Write Your Review
                    </h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="All"
                             class="alert alert-danger"></div>

                        <input type="hidden" asp-for="BookId" />

                        <!-- Star Rating -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                Your Rating
                                <span class="text-danger">*</span>
                            </label>
                            <div class="star-rating d-flex gap-2">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input
                                                          visually-hidden"
                                               type="radio"
                                               asp-for="Rating"
                                               value="@i"
                                               id="star@i" />
                                        <label class="form-check-label
                                                          star-label fs-3"
                                               for="star@i"
                                               title="@i star">
                                            <i class="bi bi-star
                                                           text-warning"></i>
                                        </label>
                                    </div>
                                }
                            </div>
                            <span asp-validation-for="Rating"
                                  class="text-danger small"></span>
                            <div id="ratingText"
                                 class="text-muted small mt-1"></div>
                        </div>

                        <!-- Comment -->
                        <div class="mb-4">
                            <label asp-for="Comment"
                                   class="form-label fw-semibold"></label>
                            <textarea asp-for="Comment"
                                      class="form-control" rows="5"
                                      placeholder="Share your thoughts about this book..."></textarea>
                            <span asp-validation-for="Comment"
                                  class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit"
                                    class="btn btn-primary px-4">
                                <i class="bi bi-send me-1"></i>
                                Submit Review
                            </button>
                            <a asp-controller="Books"
                               asp-action="Details"
                               asp-route-id="@Model.BookId"
                               class="btn btn-outline-secondary px-4">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        const ratings = {
            1: "Poor", 2: "Fair", 3: "Good",
            4: "Very Good", 5: "Excellent"
        };

        document.querySelectorAll('input[name="Rating"]')
            .forEach(input => {
                input.addEventListener('change', function () {
                    const val = parseInt(this.value);
                    // Update star icons
                    document.querySelectorAll('.star-label i')
                        .forEach((star, idx) => {
                            star.className = idx < val
                                ? 'bi bi-star-fill text-warning'
                                : 'bi bi-star text-warning';
                        });
                    document.getElementById('ratingText')
                        .textContent = ratings[val] || '';
                });
            });
    </script>
}