@model IEnumerable<LibraryManagementSystem.Models.Feedback>
@{
    ViewData["Title"] = "Manage Feedback";
}

<div class="container-fluid mt-4 px-4">
    <div class="page-header mb-4">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 class="fw-bold mb-0">
                    <i class="bi bi-star me-2"></i>
                    Manage Feedback & Ratings
                </h2>
                <p class="mb-0 mt-1 opacity-75">
                    Review and approve member submissions
                </p>
            </div>
            @if (ViewBag.PendingCount > 0)
            {
                <span class="badge bg-warning text-dark fs-6 px-3 py-2">
                    <i class="bi bi-clock me-1"></i>
                    @ViewBag.PendingCount Pending
                </span>
            }
        </div>
    </div>

    <!-- Filter Tabs -->
    <div class="card mb-4">
        <div class="card-body py-3">
            <div class="d-flex gap-2">
                <a asp-action="Manage"
                   class="btn btn-sm @(ViewBag.Filter == null ? "btn-primary" : "btn-outline-primary")">
                    All (@Model.Count())
                </a>
                <a asp-action="Manage"
                   asp-route-filter="pending"
                   class="btn btn-sm @(ViewBag.Filter == "pending" ? "btn-warning" : "btn-outline-warning")">
                    Pending (@ViewBag.PendingCount)
                </a>
                <a asp-action="Manage"
                   asp-route-filter="approved"
                   class="btn btn-sm @(ViewBag.Filter == "approved" ? "btn-success" : "btn-outline-success")">
                    Approved
                </a>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="card text-center py-5">
            <div class="card-body">
                <i class="bi bi-star text-muted"
                   style="font-size:3rem"></i>
                <h5 class="mt-3 text-muted">No feedback found</h5>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var fb in Model)
            {
                <div class="col-lg-6">
                    <div class="card h-100 @(!fb.IsApproved ? "border-warning" : "border-success")">

                        <div class="card-header d-flex
                                                    justify-content-between
                                                    align-items-center">
                            <div>
                                <strong>@fb.Book?.Title</strong>
                                <br />
                                <small class="text-muted">
                                    by @fb.User?.FullName
                                </small>
                            </div>
                            @if (fb.IsApproved)
                            {
                                <span class="badge bg-success">
                                    Approved
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">
                                    Pending
                                </span>
                            }
                        </div>

                        <div class="card-body">
                            <div class="text-warning mb-2">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <i class="bi @(i <= fb.Rating ? "bi-star-fill" : "bi-star")"></i>
                                }
                            <span class="text-muted ms-2 small">
                                @fb.Rating/5
                            </span>
                        </div>

                        <p class="text-muted mb-3">
                            @(string.IsNullOrEmpty(fb.Comment)
                                                    ? "No comment provided."
                                                    : fb.Comment)
                    </p>

                            <small class="text-muted">
                                <i class="bi bi-calendar me-1"></i>
                                Submitted:
                                @fb.SubmittedDate.ToString("MMM dd, yyyy")
                            </small>
                        </div>

                        <div class="card-footer d-flex gap-2">
                    @if (!fb.IsApproved)
                            {
                                <form asp-action="Approve"
                                      asp-route-id="@fb.Id"
                                      method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="btn btn-sm btn-success">
                                        <i class="bi bi-check-lg me-1"></i>
                                        Approve
                                    </button>
                                </form>
                            }
                            <form asp-action="Delete"
                                  asp-route-id="@fb.Id"
                                  method="post"
                                  onsubmit="return confirm('Delete this review?')">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash me-1"></i>
                                    Delete
                                </button>
                            </form>
                        </div>

                    </div>
                </div>
            }
        </div>
    }
</div>