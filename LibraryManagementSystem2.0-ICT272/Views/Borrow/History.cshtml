@model IEnumerable<LibraryManagementSystem.Models.BorrowRecord>
@{
    ViewData["Title"] = "Borrow History";
}

<div class="container mt-4">
    <div class="page-header mb-4">
        <h2 class="fw-bold mb-0">
            <i class="bi bi-clock-history me-2"></i>
            My Borrow History
        </h2>
        <p class="mb-0 mt-1 opacity-75">
            All your past and current borrows
        </p>
    </div>

    @if (!Model.Any())
    {
        <div class="card text-center py-5">
            <div class="card-body">
                <i class="bi bi-journal-x text-muted"
                   style="font-size:3rem"></i>
                <h5 class="mt-3 text-muted">No borrow history yet</h5>
                <a asp-controller="Books" asp-action="Index"
                   class="btn btn-primary mt-3">
                    Browse Books
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card stat-card stat-card-primary text-center p-3">
                    <h4 class="fw-bold mb-0">@Model.Count()</h4>
                    <small class="text-muted">Total Borrows</small>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card stat-card stat-card-success text-center p-3">
                    <h4 class="fw-bold mb-0 text-success">
                        @Model.Count(b => b.Status ==
                        LibraryManagementSystem.Models.BorrowStatus.Returned)
                </h4>
                <small class="text-muted">Returned</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stat-card stat-card-warning text-center p-3">
                <h4 class="fw-bold mb-0 text-warning">
                    @Model.Count(b =>
                                        b.Status == LibraryManagementSystem.Models.BorrowStatus.Borrowed
                                        || b.Status == LibraryManagementSystem.Models.BorrowStatus.Renewed)
                </h4>
                <small class="text-muted">Active</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stat-card stat-card-danger text-center p-3">
                <h4 class="fw-bold mb-0 text-danger">
                    @Model.Count(b => b.Fine != null)
                </h4>
                <small class="text-muted">Fines Incurred</small>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Book</th>
                            <th>Borrowed On</th>
                            <th>Due Date</th>
                            <th>Returned On</th>
                            <th>Status</th>
                            <th>Fine</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var record in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>@record.Book?.Title</strong>
                                        <br />
                                        <small class="text-muted">
                                            @record.Book?.Author
                                        </small>
                                    </td>
                                    <td>@record.BorrowDate.ToString("MMM dd, yyyy")</td>
                                    <td>@record.DueDate.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        @(record.ReturnDate.HasValue
                                                                        ? record.ReturnDate.Value.ToString("MMM dd, yyyy")
                                                                        : "—")
                            </td>
                            <td>
                                @switch (record.Status)
                                        {
                                            case LibraryManagementSystem.Models.BorrowStatus.Borrowed:
                                            case LibraryManagementSystem.Models.BorrowStatus.Renewed:
                                                <span class="badge badge-borrowed px-2 py-1">
                                                    @record.Status
                                                </span>
                                                break;
                                            case LibraryManagementSystem.Models.BorrowStatus.Returned:
                                                <span class="badge badge-returned px-2 py-1">
                                                    Returned
                                                </span>
                                                break;
                                            case LibraryManagementSystem.Models.BorrowStatus.Overdue:
                                                <span class="badge badge-overdue px-2 py-1">
                                                    Overdue
                                                </span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        @if (record.Fine != null)
                                        {
                                            <span class="@(record.Fine.IsPaid ? "text-success" : "text-danger") fw-bold">
                                                $@record.Fine.Amount.ToString("F2")
                                            </span>
                                            <br />
                                            <small class="@(record.Fine.IsPaid ? "text-success" : "text-danger")">
                                                @(record.Fine.IsPaid ? "Paid" : "Unpaid")
                                            </small>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td>
                                        @if (record.Status == LibraryManagementSystem.Models.BorrowStatus.Returned)
                                        {
                                            <a asp-controller="Feedback"
                                               asp-action="Create"
                                               asp-route-bookId="@record.BookId"
                                               class="btn btn-sm btn-outline-warning">
                                                <i class="bi bi-star me-1"></i> Review
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>