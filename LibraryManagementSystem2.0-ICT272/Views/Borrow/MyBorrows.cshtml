@model IEnumerable<LibraryManagementSystem.Models.BorrowRecord>
@{
    ViewData["Title"] = "My Borrows";
    var reservations = ViewBag.Reservations as
        List<LibraryManagementSystem.Models.Reservation>
        ?? new List<LibraryManagementSystem.Models.Reservation>();
    int maxRenewals = ViewBag.MaxRenewals ?? 2;
}

<div class="container mt-4">
    <div class="page-header mb-4">
        <h2 class="fw-bold mb-0">
            <i class="bi bi-bookmark me-2"></i> My Borrows
        </h2>
        <p class="mb-0 mt-1 opacity-75">Your currently borrowed books</p>
    </div>

    @if (!Model.Any())
    {
        <div class="card text-center py-5 mb-4">
            <div class="card-body">
                <i class="bi bi-book text-muted" style="font-size:3rem"></i>
                <h5 class="mt-3 text-muted">You have no active borrows</h5>
                <a asp-controller="Books" asp-action="Index"
                   class="btn btn-primary mt-3">
                    <i class="bi bi-search me-1"></i> Browse Books
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4 mb-4">
            @foreach (var record in Model)
            {
                bool isOverdue = record.Status ==
                LibraryManagementSystem.Models.BorrowStatus.Overdue;
                int daysLeft = (record.DueDate - DateTime.Now).Days;
                bool canRenew = record.RenewalsUsed < maxRenewals && !isOverdue;

                <div class="col-md-6">
                    <div class="card h-100 @(isOverdue ? "border-danger" : "border-0")">
                        <div class="card-body">
                            <div class="d-flex gap-3">
                                @if (!string.IsNullOrEmpty(record.Book?.CoverImagePath))
                                {
                                    <img src="@record.Book.CoverImagePath"
                                         style="width:70px; height:90px; object-fit:cover; border-radius:6px;"
                                         alt="cover" />
                                }
                                else
                                {
                                    <div style="width:70px; height:90px; background:#e8edf2; border-radius:6px; display:flex; align-items:center; justify-content:center; font-size:1.8rem; color:#8fa3b1;">
                                        <i class="bi bi-book"></i>
                                    </div>
                                }

                                <div class="flex-grow-1">
                                    <h6 class="fw-bold mb-1">@record.Book?.Title</h6>
                                    <p class="text-muted small mb-2">@record.Book?.Author</p>

                                    @if (isOverdue)
                                    {
                                        <span class="badge badge-overdue px-2 py-1 mb-2 d-inline-block">
                                            <i class="bi bi-exclamation-triangle me-1"></i> Overdue
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-borrowed px-2 py-1 mb-2 d-inline-block">
                                            Active
                                        </span>
                                    }

                                    <p class="small mb-1 @(isOverdue ? "text-danger fw-bold" : daysLeft <= 3 ? "text-warning fw-bold" : "text-muted")">
                                        <i class="bi bi-calendar me-1"></i>
                                        Due: @record.DueDate.ToString("MMM dd, yyyy")
                                        @if (isOverdue)
                                        {
                                            <span> — Overdue!</span>
                                        }
                                        else if (daysLeft == 0)
                                        {
                                            <span> — Due Today!</span>
                                        }
                                        else
                                        {
                                            <span> (@daysLeft days left)</span>
                                        }
                                    </p>

                                    <p class="small text-muted mb-2">
                                        <i class="bi bi-arrow-repeat me-1"></i>
                                        Renewals: @record.RenewalsUsed / @maxRenewals
                                    </p>

                                    @if (record.Fine != null && !record.Fine.IsPaid)
                                    {
                                        <div class="alert alert-danger py-1 px-2 small mb-2">
                                            <i class="bi bi-cash me-1"></i>
                                            Fine: $@record.Fine.Amount.ToString("F2")
                                        </div>
                                    }

                                    @if (canRenew)
                                    {
                                        <form asp-action="Renew"
                                              asp-route-id="@record.Id"
                                              method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit"
                                                    class="btn btn-sm btn-outline-primary">
                                                <i class="bi bi-arrow-repeat me-1"></i> Renew
                                            </button>
                                        </form>
                                    }
                                    else if (!isOverdue)
                                    {
                                        <small class="text-muted">Max renewals reached</small>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @if (reservations.Any())
    {
        <h5 class="fw-bold mb-3">
            <i class="bi bi-clock me-2"></i> My Reservations
        </h5>
        <div class="card mb-4">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Book</th>
                            <th>Reserved On</th>
                            <th>Expires On</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var res in reservations)
                        {
                            <tr>
                                <td>
                                    <strong>@res.Book?.Title</strong>
                                    <br />
                                    <small class="text-muted">@res.Book?.Author</small>
                                </td>
                                <td>@res.ReservationDate.ToString("MMM dd, yyyy")</td>
                                <td>@res.ExpiryDate.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <span class="badge badge-reserved px-2 py-1">
                                        Pending
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <a asp-action="History" class="btn btn-outline-secondary">
        <i class="bi bi-clock-history me-1"></i> View Full Borrow History
    </a>
</div>