@model LibraryManagementSystem.Models.ApplicationUser
@{
    ViewData["Title"] = "Member Details";
    var borrows = ViewBag.Borrows as
        IEnumerable<LibraryManagementSystem.Models.BorrowRecord>
        ?? Enumerable.Empty<LibraryManagementSystem
            .Models.BorrowRecord>();
    var fines = ViewBag.Fines as
        IEnumerable<LibraryManagementSystem.Models.Fine>
        ?? Enumerable.Empty<LibraryManagementSystem.Models.Fine>();
}

<div class="container-fluid mt-4 px-4">

    <div class="page-header mb-4">
        <div class="d-flex justify-content-between
                    align-items-center">
            <div>
                <h2 class="fw-bold mb-0">
                    <i class="bi bi-person-circle me-2"></i>
                    @Model.FullName
                </h2>
                <p class="mb-0 mt-1 opacity-75">
                    Member since
                    @Model.DateJoined.ToString("MMMM dd, yyyy")
                </p>
            </div>
            <a asp-action="Members"
               class="btn btn-outline-light">
                <i class="bi bi-arrow-left me-1"></i>
                Back to Members
            </a>
        </div>
    </div>

    <div class="row g-4 mb-4">

        <!-- Member Info Card -->
        <div class="col-lg-4">
            <div class="card h-100">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-person me-2"></i>
                        Member Information
                    </h5>
                </div>
                <div class="card-body">
                    <div class="text-center mb-4">
                        <div class="member-avatar-lg mx-auto">
                            @Model.FirstName.Substring(0, 1).ToUpper()
                        </div>
                        <h5 class="fw-bold mt-3 mb-1">
                            @Model.FullName
                        </h5>
                        @if (Model.IsActive)
                        {
                            <span class="badge bg-success">
                                Active Member
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">
                                Inactive
                            </span>
                        }
                    </div>

                    <table class="table table-borderless table-sm">
                        <tr>
                            <td class="text-muted fw-semibold"
                                style="width:90px">
                                Email
                            </td>
                            <td class="small">@Model.Email</td>
                        </tr>
                        <tr>
                            <td class="text-muted fw-semibold">
                                Phone
                            </td>
                            <td class="small">
                                @(Model.PhoneNumber ?? "Not provided")
                            </td>
                        </tr>
                        <tr>
                            <td class="text-muted fw-semibold">
                                Address
                            </td>
                            <td class="small">
                                @(Model.Address ?? "Not provided")
                            </td>
                        </tr>
                        <tr>
                            <td class="text-muted fw-semibold">
                                Joined
                            </td>
                            <td class="small">
                                @Model.DateJoined
                                .ToString("MMM dd, yyyy")
                            </td>
                        </tr>
                    </table>

                    <hr />

                    <form asp-action="ToggleMemberStatus"
                          asp-route-id="@Model.Id"
                          method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit"
                                class="btn w-100
                                @(Model.IsActive
                                                                                                    ? "btn-outline-warning"
                                                                                                    : "btn-outline-success")">
                            <i class="bi @(Model.IsActive
                                                                                              ? "bi-person-x"
                                                                                              : "bi-person-check") me-2"></i>
                            @(Model.IsActive
                                                        ? "Deactivate Account"
                                                        : "Activate Account")
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Stats + History -->
        <div class="col-lg-8">

            <!-- Summary Stats -->
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <div class="card stat-card stat-card-primary
                                text-center p-3">
                        <h3 class="fw-bold mb-0">
                            @borrows.Count()
                        </h3>
                        <small class="text-muted">
                            Total Borrows
                        </small>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card stat-card stat-card-success
                                text-center p-3">
                        <h3 class="fw-bold mb-0 text-success">
                            @borrows.Count(b => b.Status ==
                                                        LibraryManagementSystem.Models
                                                        .BorrowStatus.Returned)
                        </h3>
                        <small class="text-muted">Returned</small>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card stat-card stat-card-warning
                                text-center p-3">
                        <h3 class="fw-bold mb-0 text-warning">
                            @borrows.Count(b =>
                                                        b.Status == LibraryManagementSystem
                                                        .Models.BorrowStatus.Borrowed
                                                        || b.Status == LibraryManagementSystem
                                                        .Models.BorrowStatus.Renewed)
                        </h3>
                        <small class="text-muted">Active</small>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card stat-card stat-card-danger
                                text-center p-3">
                        <h3 class="fw-bold mb-0 text-danger">
                            $@(((decimal)ViewBag.UnpaidFines)
                                                        .ToString("F2"))
                        </h3>
                        <small class="text-muted">
                            Unpaid Fines
                        </small>
                    </div>
                </div>
            </div>

            <!-- Borrow History -->
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-clock-history me-2"></i>
                        Borrow History
                        <span class="badge bg-white
                                     text-primary ms-2">
                            @borrows.Count()
                        </span>
                    </h5>
                </div>
                <div class="card-body p-0">
                    @if (!borrows.Any())
                    {
                        <div class="text-center py-4">
                            <i class="bi bi-book text-muted"
                               style="font-size:2rem"></i>
                            <p class="text-muted mt-2">
                                No borrow history yet
                            </p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Book</th>
                                        <th>Borrowed On</th>
                                        <th>Due Date</th>
                                        <th>Returned On</th>
                                        <th>Status</th>
                                        <th>Fine</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var b in borrows)
                                    {
                                        <tr>
                                            <td>
                                                <strong>
                                                    @b.Book?.Title
                                                </strong>
                                                <br />
                                                <small class="text-muted">
                                                    @b.Book?.Author
                                                </small>
                                            </td>
                                            <td class="small text-muted">
                                                @b.BorrowDate.ToString(
                                                "MMM dd, yyyy")
                                    </td>
                                    <td class="small">
                                        <span class="@(
                                                                                                                                                b.DueDate < DateTime.Now
                                                                                                                                                && b.Status !=
                                                                                                                                                LibraryManagementSystem
                                                                                                                                                .Models.BorrowStatus
                                                                                                                                                .Returned
                                                                                                                                                ? "text-danger fw-bold"
                                                                                                                                                : "")">
                                            @b.DueDate.ToString(
                                                                                        "MMM dd, yyyy")
                                        </span>
                                    </td>
                                    <td class="small text-muted">
                                        @(b.ReturnDate.HasValue
                                                                                ? b.ReturnDate.Value
                                                                                .ToString(
                                                                                "MMM dd, yyyy")
                                                                                : "—")
                                    </td>
                                    <td>
                                        @switch (b.Status)
                                                {
                                                    case LibraryManagementSystem
                                                                                .Models.BorrowStatus
                                                                                .Borrowed:
                                                    case LibraryManagementSystem
                                                                                .Models.BorrowStatus
                                                                                .Renewed:
                                                        <span class="badge
                                                                                            badge-borrowed">
                                                            @b.Status
                                                        </span>
                                                        break;
                                                    case LibraryManagementSystem
                                                                                .Models.BorrowStatus
                                                                                .Returned:
                                                        <span class="badge
                                                                                            badge-returned">
                                                            Returned
                                                        </span>
                                                        break;
                                                    case LibraryManagementSystem
                                                                                .Models.BorrowStatus
                                                                                .Overdue:
                                                        <span class="badge
                                                                                            badge-overdue">
                                                            Overdue
                                                        </span>
                                                        break;
                                                }
                                            </td>
                                            <td>
                                                @if (b.Fine != null)
                                                {
                                                    <span class="@(b.Fine
                                                                                                                                                                            .IsPaid
                                                                                                                                                                            ? "text-success"
                                                                                                                                                                            : "text-danger")
                                                        fw-bold small">
                                            $@b.Fine.Amount
                                            .ToString("F2")
                                        </span>
                                        <br />
                                        <small class="@(b.Fine
                                                                                                                                                      .IsPaid
                                                                                                                                                      ? "text-success"
                                                                                                                                                      : "text-muted")">
                                            @(b.Fine.IsPaid
                                                                                        ? "Paid"
                                                                                        : "Unpaid")
                                        </small>
                                                                                }
                                                else
                                                {
                                                    <span class="text-muted">
                                                        —
                                                    </span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <!-- Fines Summary -->
            @if (fines.Any())
            {
                <div class="card">
                    <div class="card-header bg-danger text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-cash me-2"></i>
                            Fines Summary
                            <span class="badge bg-white
                                                 text-danger ms-2">
                                $@(((decimal)ViewBag.TotalFines)
                                                            .ToString("F2")) total
                        </span>
                    </h5>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Book</th>
                                <th>Amount</th>
                                <th>Reason</th>
                                <th>Issued On</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var fine in fines)
                                {
                                    <tr>
                                        <td>
                                            <strong>
                                                @fine.BorrowRecord
                                                ?.Book?.Title
                                            </strong>
                                        </td>
                                        <td>
                                            <strong class="@(fine.IsPaid
                                                                                                                                                        ? "text-success"
                                                                                                                                                        : "text-danger")">
                                        $@fine.Amount
                                        .ToString("F2")
                                    </strong>
                                </td>
                                <td class="small text-muted">
                                    @fine.Reason
                                </td>
                                <td class="small text-muted">
                                    @fine.IssuedDate.ToString(
                                                                        "MMM dd, yyyy")
                                </td>
                                <td>
                                    @if (fine.IsPaid)
                                            {
                                                <span class="badge
                                                                                     bg-success">
                                                    Paid
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge
                                                                                     bg-danger">
                                                    Unpaid
                                                </span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
            else
            {
                <div class="card">
                    <div class="card-body text-center py-4">
                        <i class="bi bi-emoji-smile text-success
                                          fs-1"></i>
                        <h5 class="mt-3 text-success">
                            No Fines!
                        </h5>
                        <p class="text-muted">
                            This member has a clean record.
                        </p>
                    </div>
                </div>
            }

        </div>
    </div>
</div>