@model IEnumerable<LibraryManagementSystem.Models.ApplicationUser>
@{
    ViewData["Title"] = "Manage Members";
    var borrowCounts = ViewBag.BorrowCounts as
        IEnumerable<dynamic>
        ?? Enumerable.Empty<dynamic>();
}

<div class="container-fluid mt-4 px-4">
    <div class="page-header mb-4">
        <div class="d-flex justify-content-between
                    align-items-center">
            <div>
                <h2 class="fw-bold mb-0">
                    <i class="bi bi-people me-2"></i>
                    Library Members
                </h2>
                <p class="mb-0 mt-1 opacity-75">
                    @Model.Count() registered members
                </p>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-people text-muted"
                       style="font-size:3rem"></i>
                    <h5 class="mt-3 text-muted">
                        No members yet
                    </h5>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Member</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>Date Joined</th>
                                <th class="text-center">
                                    Total Borrows
                                </th>
                                <th class="text-center">
                                    Active
                                </th>
                                <th class="text-center">
                                    Overdue
                                </th>
                                <th>Status</th>
                                <th class="text-center">
                                    Actions
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var member in Model)
                            {
                                var bc = borrowCounts
                                .FirstOrDefault(x =>
                                x.UserId == member.Id);
                                int total = bc != null
                                ? (int)bc.Total : 0;
                                int active = bc != null
                                ? (int)bc.Active : 0;
                                int overdue = bc != null
                                ? (int)bc.Overdue : 0;

                                <tr>
                                    <td>
                                        <div class="d-flex
                                                                    align-items-center
                                                                    gap-2">
                                            <div class="member-avatar">
                                                @member.FirstName
                                                .Substring(0, 1)
                                                .ToUpper()
                                            </div>
                                            <div>
                                                <strong>
                                                    @member.FullName
                                                </strong>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-muted small">
                                        @member.Email
                                    </td>
                                    <td class="text-muted small">
                                        @(member.PhoneNumber ?? "—")
                                    </td>
                                    <td class="text-muted small">
                                        @member.DateJoined
                                        .ToString("MMM dd, yyyy")
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-primary">
                                            @total
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-warning
                                                                     text-dark">
                                            @active
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        @if (overdue > 0)
                                        {
                                            <span class="badge bg-danger">
                                                @overdue
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">
                                                0
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        @if (member.IsActive)
                                        {
                                            <span class="badge bg-success">
                                                Active
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">
                                                Inactive
                                            </span>
                                        }
                                </td>
                                <td class="text-center">
                                    <a asp-action="MemberDetails"
                                       asp-route-id="@member.Id"
                                       class="btn btn-sm
                                                          btn-outline-primary">
                                        <i class="bi bi-eye me-1"></i>
                                        View
                                    </a>
                                    <form asp-action="ToggleMemberStatus"
                                          asp-route-id="@member.Id"
                                          method="post"
                                          class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="btn btn-sm
                                                            @(member.IsActive
                                                                                                                                                        ? "btn-outline-warning"
                                                                                                                                                        : "btn-outline-success")">
                                            @(member.IsActive
                                                                                    ? "Deactivate"
                                                                                    : "Activate")
                                    </button>
                                </form>
                            </td>
                        </tr>
                                                }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>