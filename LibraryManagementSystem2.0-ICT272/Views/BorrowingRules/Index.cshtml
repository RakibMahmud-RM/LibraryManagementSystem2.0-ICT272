@model IEnumerable<LibraryManagementSystem.Models.BorrowingRule>
@{
    ViewData["Title"] = "Borrowing Rules";
}

<div class="container mt-4">
    <div class="page-header mb-4">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 class="fw-bold mb-0">
                    <i class="bi bi-sliders me-2"></i> Borrowing Rules
                </h2>
                <p class="mb-0 mt-1 opacity-75">
                    Configure loan duration, renewals and fines
                </p>
            </div>
            <a asp-action="Create" class="btn btn-warning fw-semibold">
                <i class="bi bi-plus-lg me-1"></i> Add Rule
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="card text-center py-5">
            <div class="card-body">
                <i class="bi bi-sliders text-muted"
                   style="font-size:3rem"></i>
                <h5 class="mt-3 text-muted">No rules configured yet</h5>
                <a asp-action="Create" class="btn btn-primary mt-3">
                    <i class="bi bi-plus-lg me-1"></i> Create First Rule
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var rule in Model)
            {
                <div class="col-lg-6">
                    <div class="card h-100 @(rule.IsActive
                                                                          ? "border-success" : "border-secondary")">
                                                                                                                 <div class="card-header d-flex
                                                                                                                                                                                                             justify-content-between
                                                                                                                                                                                                             align-items-center
                                                    @(rule.IsActive
                                                                                                  ? "bg-success" : "bg-secondary")
                                    text-white">
                    <h6 class="mb-0 fw-bold">
                        <i class="bi bi-sliders me-2"></i>
                        @rule.RuleName
                    </h6>
                    @if (rule.IsActive)
                            {
                                <span class="badge bg-white text-success">
                                    Active
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-white text-secondary">
                                    Inactive
                                </span>
                            }
                        </div>
                        <div class="card-body">
                            <div class="row g-3 text-center mb-3">
                                <div class="col-3">
                                    <div class="rule-stat">
                                        <h4 class="fw-bold text-primary mb-0">
                                            @rule.LoanDurationDays
                                        </h4>
                                        <small class="text-muted">
                                            Loan Days
                                        </small>
                                    </div>
                                </div>
                                <div class="col-3">
                                    <div class="rule-stat">
                                        <h4 class="fw-bold text-success mb-0">
                                            @rule.MaxRenewals
                                        </h4>
                                        <small class="text-muted">
                                            Max Renewals
                                        </small>
                                    </div>
                                </div>
                                <div class="col-3">
                                    <div class="rule-stat">
                                        <h4 class="fw-bold text-danger mb-0">
                                            $@rule.OverduePenaltyPerDay
                                        </h4>
                                        <small class="text-muted">
                                            Per Day Fine
                                        </small>
                                    </div>
                                </div>
                                <div class="col-3">
                                    <div class="rule-stat">
                                        <h4 class="fw-bold text-warning mb-0">
                                            @rule.MaxBorrowableItems
                                        </h4>
                                        <small class="text-muted">
                                            Max Items
                                        </small>
                                    </div>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(rule.Notes))
                            {
                                <p class="text-muted small mb-3">
                                    <i class="bi bi-info-circle me-1"></i>
                                    @rule.Notes
                                </p>
                            }

                            <div class="d-flex gap-2">
                                <a asp-action="Edit"
                                   asp-route-id="@rule.Id"
                                   class="btn btn-sm btn-outline-warning
                                                          flex-grow-1">
                                    <i class="bi bi-pencil me-1"></i> Edit
                                </a>
                                <form asp-action="Delete"
                                      asp-route-id="@rule.Id"
                                      method="post"
                                      onsubmit="return confirm(
                                                        'Delete this rule?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="btn btn-sm
                                                                   btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>