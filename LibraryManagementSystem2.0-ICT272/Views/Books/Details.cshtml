@model LibraryManagementSystem.Models.Book
@{
    ViewData["Title"] = Model.Title;
}

<div class="container mt-4">
    <div class="row">
        <div class="col-lg-4 mb-4">
            @if (!string.IsNullOrEmpty(Model.CoverImagePath))
            {
                <img src="@Model.CoverImagePath"
                     alt="@Model.Title"
                     class="img-fluid rounded"
                     style="width:100%;
                                max-height:400px;
                                object-fit:cover;" />
            }
            else
            {
                <div class="book-cover-placeholder rounded"
                     style="height:300px">
                    <i class="bi bi-book"></i>
                </div>
            }
        </div>

        <div class="col-lg-8">
            <div class="page-header mb-3">
                <h2 class="fw-bold mb-1">@Model.Title</h2>
                <p class="mb-0 opacity-75">
                    by @Model.Author
                </p>
            </div>

            <div class="card mb-3">
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <small class="text-muted d-block">
                                ISBN
                            </small>
                            <strong>@Model.ISBN</strong>
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted d-block">
                                Publisher
                            </small>
                            <strong>
                                @(Model.Publisher ?? "N/A")
                            </strong>
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted d-block">
                                Published Year
                            </small>
                            <strong>@Model.PublishedYear</strong>
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted d-block">
                                Total Copies
                            </small>
                            <strong>@Model.TotalCopies</strong>
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted d-block">
                                Available
                            </small>
                            @if (Model.AvailableCopies > 0)
                            {
                                <span class="badge bg-success">
                                    @Model.AvailableCopies Available
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger">
                                    Not Available
                                </span>
                            }
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted d-block">
                                Categories
                            </small>
                            @foreach (var bc in Model.BookCategories)
                            {
                                <span class="badge bg-light
                                                 text-dark border me-1">
                                    @bc.Category?.Name
                                </span>
                            }
                        </div>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div class="card mb-3">
                    <div class="card-body">
                        <h6 class="fw-bold mb-2">Description</h6>
                        <p class="text-muted mb-0">
                            @Model.Description
                        </p>
                    </div>
                </div>
            }

            <div class="d-flex gap-2 flex-wrap">
                @if (User.IsInRole("Member") &&
                                Model.AvailableCopies > 0)
                {
                    <form asp-controller="Borrow"
                          asp-action="BorrowBook"
                          method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="bookId"
                               value="@Model.Id" />
                        <button type="submit"
                                class="btn btn-primary">
                            <i class="bi bi-bookmark-plus me-1"></i>
                            Borrow This Book
                        </button>
                    </form>
                }
                @if (User.IsInRole("Member") &&
                                Model.AvailableCopies == 0)
                {
                    <form asp-controller="Borrow"
                          asp-action="Reserve"
                          method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="bookId"
                               value="@Model.Id" />
                        <button type="submit"
                                class="btn btn-warning">
                            <i class="bi bi-bookmark me-1"></i>
                            Reserve Book
                        </button>
                    </form>
                }
                @if (User.IsInRole("Member"))
                {
                    <a asp-controller="Feedback"
                       asp-action="Create"
                       asp-route-bookId="@Model.Id"
                       class="btn btn-outline-secondary">
                        <i class="bi bi-star me-1"></i>
                        Leave a Review
                    </a>
                }
                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Books"
                       asp-action="Edit"
                       asp-route-id="@Model.Id"
                       class="btn btn-outline-warning">
                        <i class="bi bi-pencil me-1"></i>
                        Edit
                    </a>
                }
                <a asp-controller="Books"
                   asp-action="Index"
                   class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>
                    Back to Books
                </a>
            </div>

            @if (Model.Feedbacks.Any(f => f.IsApproved))
            {
                <div class="card mt-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-star me-2"></i>
                            Member Reviews
                        </h5>
                    </div>
                    <div class="card-body">
                        @foreach (var fb in Model.Feedbacks
                                            .Where(f => f.IsApproved))
                        {
                            <div class="border-bottom pb-3 mb-3">
                                <div class="d-flex align-items-center
                                                    gap-2 mb-1">
                                    <strong>
                                        @fb.User?.FirstName
                                    </strong>
                                    <span class="text-warning">
                                        @for (int i = 0;
                                                                        i < fb.Rating; i++)
                                        {
                                            <i class="bi bi-star-fill"></i>
                                        }
                                    </span>
                                    <small class="text-muted">
                                        @fb.SubmittedDate.ToString("MMM dd, yyyy")
                                    </small>
                                </div>
                                <p class="mb-0 text-muted small">
                                    @fb.Comment
                                </p>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>