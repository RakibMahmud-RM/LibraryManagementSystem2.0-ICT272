@model LibraryManagementSystem.ViewModels.BookViewModel
@{
    ViewData["Title"] = "Edit Book";
}

<div class="container mt-4">
    <div class="page-header mb-4">
        <h2 class="fw-bold mb-0">
            <i class="bi bi-pencil me-2"></i> Edit Book
        </h2>
        <p class="mb-0 mt-1 opacity-75">
            Update book information
        </p>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-body p-4">
                    <form asp-controller="Books"
                          asp-action="Edit"
                          method="post"
                          enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="All"
                             class="alert alert-danger"></div>

                        <input type="hidden" asp-for="Id" />

                        <div class="row mb-3">
                            <div class="col-md-8">
                                <label asp-for="Title"
                                       class="form-label fw-semibold">
                                </label>
                                <input asp-for="Title"
                                       class="form-control" />
                                <span asp-validation-for="Title"
                                      class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="ISBN"
                                       class="form-label fw-semibold">
                                </label>
                                <input asp-for="ISBN"
                                       class="form-control" />
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Author"
                                       class="form-label fw-semibold">
                                </label>
                                <input asp-for="Author"
                                       class="form-control" />
                                <span asp-validation-for="Author"
                                      class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Publisher"
                                       class="form-label fw-semibold">
                                </label>
                                <input asp-for="Publisher"
                                       class="form-control" />
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label asp-for="PublishedYear"
                                       class="form-label fw-semibold">
                                </label>
                                <input asp-for="PublishedYear"
                                       class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label asp-for="TotalCopies"
                                       class="form-label fw-semibold">
                                </label>
                                <input asp-for="TotalCopies"
                                       class="form-control"
                                       type="number" min="1" />
                                <span asp-validation-for="TotalCopies"
                                      class="text-danger small"></span>
                            </div>
                            <div class="col-md-4 d-flex align-items-end">
                                <div class="form-check mb-2">
                                    <input asp-for="IsActive"
                                           class="form-check-input" />
                                    <label asp-for="IsActive"
                                           class="form-check-label fw-semibold">
                                        Active
                                    </label>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description"
                                   class="form-label fw-semibold">
                            </label>
                            <textarea asp-for="Description"
                                      class="form-control"
                                      rows="4"></textarea>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Categories
                            </label>
                            <div class="row">
                                @foreach (var cat in
                                                                Model.AvailableCategories)
                                {
                                    <div class="col-md-4">
                                        <div class="form-check">
                                            <input type="checkbox"
                                                   name="SelectedCategoryIds"
                                                   value="@cat.Value"
                                                   class="form-check-input"
                                                   id="cat_@cat.Value"
                                                   @(Model.SelectedCategoryIds
                                                                                                  .Contains(int.Parse(
                                                                                                  cat.Value))
                                                                                                  ? "checked" : "") />
                                        <label class="form-check-label"
                                               for="cat_@cat.Value">
                                            @cat.Text
                                        </label>
                                    </div>
                                </div>
                                                                }
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="CoverImage"
                                   class="form-label fw-semibold">
                            </label>
                            @if (!string.IsNullOrEmpty(
                                                        Model.ExistingCoverImagePath))
                            {
                                <div class="mb-2">
                                    <img src="@Model.ExistingCoverImagePath"
                                         alt="Current cover"
                                         style="height:100px;
                                                    border-radius:6px;
                                                    object-fit:cover;" />
                                    <small class="text-muted ms-2">
                                        Current cover image
                                    </small>
                                </div>
                            }
                            <input asp-for="CoverImage"
                                   type="file"
                                   class="form-control"
                                   accept="image/*" />
                            <div class="form-text">
                                Leave empty to keep current image
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit"
                                    class="btn btn-primary px-4">
                                <i class="bi bi-check-lg me-1"></i>
                                Save Changes
                            </button>
                            <a asp-controller="Books"
                               asp-action="Index"
                               class="btn btn-outline-secondary px-4">
                                <i class="bi bi-x-lg me-1"></i>
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}