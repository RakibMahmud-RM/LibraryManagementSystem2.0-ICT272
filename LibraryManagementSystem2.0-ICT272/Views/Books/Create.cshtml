@model LibraryManagementSystem.ViewModels.BookViewModel
@{
    ViewData["Title"] = "Add New Book";
}

<div class="container mt-4">
    <div class="page-header mb-4">
        <h2 class="fw-bold mb-0">
            <i class="bi bi-plus-circle me-2"></i> Add New Book
        </h2>
        <p class="mb-0 mt-1 opacity-75">
            Fill in the details below to add a book
        </p>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-body p-4">
                    <form asp-controller="Books"
                          asp-action="Create"
                          method="post"
                          enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="All"
                             class="alert alert-danger"></div>

                        <div class="row mb-3">
                            <div class="col-md-8">
                                <label asp-for="Title"
                                       class="form-label fw-semibold">
                                </label>
                                <input asp-for="Title"
                                       class="form-control"
                                       placeholder="Enter book title" />
                                <span asp-validation-for="Title"
                                      class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="ISBN"
                                       class="form-label fw-semibold">
                                </label>
                                <input asp-for="ISBN"
                                       class="form-control"
                                       placeholder="978-X-XX-XXXXXX-X" />
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Author"
                                       class="form-label fw-semibold">
                                </label>
                                <input asp-for="Author"
                                       class="form-control"
                                       placeholder="Author name" />
                                <span asp-validation-for="Author"
                                      class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Publisher"
                                       class="form-label fw-semibold">
                                </label>
                                <input asp-for="Publisher"
                                       class="form-control"
                                       placeholder="Publisher name" />
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label asp-for="PublishedYear"
                                       class="form-label fw-semibold">
                                </label>
                                <input asp-for="PublishedYear"
                                       class="form-control"
                                       placeholder="e.g. 2023" />
                            </div>
                            <div class="col-md-4">
                                <label asp-for="TotalCopies"
                                       class="form-label fw-semibold">
                                </label>
                                <input asp-for="TotalCopies"
                                       class="form-control"
                                       type="number" min="1" />
                                <span asp-validation-for="TotalCopies"
                                      class="text-danger small"></span>
                            </div>
                            <div class="col-md-4 d-flex align-items-end">
                                <div class="form-check mb-2">
                                    <input asp-for="IsActive"
                                           class="form-check-input" />
                                    <label asp-for="IsActive"
                                           class="form-check-label fw-semibold">
                                        Active
                                    </label>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description"
                                   class="form-label fw-semibold">
                            </label>
                            <textarea asp-for="Description"
                                      class="form-control"
                                      rows="4"
                                      placeholder="Brief summary...">
                            </textarea>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Categories
                            </label>
                            @if (Model.AvailableCategories.Any())
                            {
                                <div class="row">
                                    @foreach (var cat in
                                                                    Model.AvailableCategories)
                                    {
                                        <div class="col-md-4">
                                            <div class="form-check">
                                                <input type="checkbox"
                                                       name="SelectedCategoryIds"
                                                       value="@cat.Value"
                                                       class="form-check-input"
                                                       id="cat_@cat.Value" />
                                                <label class="form-check-label"
                                                       for="cat_@cat.Value">
                                                    @cat.Text
                                                </label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-warning py-2">
                                    No categories yet.
                                    <a asp-controller="Categories"
                                       asp-action="Index">
                                        Add categories first
                                    </a>
                                </div>
                            }
                        </div>

                        <div class="mb-4">
                            <label asp-for="CoverImage"
                                   class="form-label fw-semibold">
                            </label>
                            <input asp-for="CoverImage"
                                   type="file"
                                   class="form-control"
                                   accept="image/*"
                                   id="coverImageInput" />
                            <div class="form-text">
                                JPG, PNG (max 5MB) — optional
                            </div>
                            <div id="imagePreview" class="mt-2 d-none">
                                <img id="previewImg" src="#"
                                     alt="Preview"
                                     style="max-height:200px;
                                            border-radius:8px;
                                            object-fit:cover;" />
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit"
                                    class="btn btn-primary px-4">
                                <i class="bi bi-check-lg me-1"></i>
                                Save Book
                            </button>
                            <a asp-controller="Books"
                               asp-action="Index"
                               class="btn btn-outline-secondary px-4">
                                <i class="bi bi-x-lg me-1"></i>
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 bg-light">
                <div class="card-body">
                    <h6 class="fw-bold mb-3">
                        <i class="bi bi-lightbulb text-warning me-2"></i>
                        Tips
                    </h6>
                    <ul class="small text-muted ps-3">
                        <li class="mb-2">
                            ISBN format: 978-X-XX-XXXXXX-X
                        </li>
                        <li class="mb-2">
                            Available copies = total copies on add
                        </li>
                        <li class="mb-2">
                            Uncheck Active to hide from members
                        </li>
                        <li class="mb-2">
                            Cover image is optional
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        document.getElementById('coverImageInput')
            .addEventListener('change', function (e) {
                const file = e.target.files[0];
                if (file) {
                    const reader = new FileReader();
                    reader.onload = function (e) {
                        document.getElementById('previewImg')
                            .src = e.target.result;
                        document.getElementById('imagePreview')
                            .classList.remove('d-none');
                    };
                    reader.readAsDataURL(file);
                }
            });
    </script>
}