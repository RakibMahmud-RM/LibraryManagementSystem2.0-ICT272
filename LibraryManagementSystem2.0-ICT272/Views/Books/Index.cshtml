@model IEnumerable<LibraryManagementSystem.Models.Book>
@{
    ViewData["Title"] = "Browse Books";
}

<div class="container-fluid mt-4 px-4">

    <!-- Page Header -->
    <div class="page-header mb-4">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 class="fw-bold mb-0">
                    <i class="bi bi-book me-2"></i> Browse Books
                </h2>
                <p class="mb-0 mt-1 opacity-75">
                    @Model.Count() books available
                </p>
            </div>
            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Books"
                   asp-action="Create"
                   class="btn btn-warning fw-semibold">
                    <i class="bi bi-plus-lg me-1"></i> Add New Book
                </a>
            }
        </div>
    </div>

    <!-- Search & Filter -->
    <div class="card mb-4">
        <div class="card-body">
            <form asp-controller="Books"
                  asp-action="Index"
                  method="get">
                <div class="row g-3 align-items-end">
                    <div class="col-md-5">
                        <label class="form-label fw-semibold">
                            Search Books
                        </label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-search"></i>
                            </span>
                            <input type="text" name="search"
                                   class="form-control"
                                   value="@ViewBag.Search"
                                   placeholder="Title, author or ISBN..." />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">
                            Filter by Category
                        </label>
                        <select name="categoryId" class="form-select">
                            <option value="">All Categories</option>
                            @foreach (var cat in ViewBag.Categories
                                                        as List<Microsoft.AspNetCore.Mvc
                                                        .Rendering.SelectListItem> ?? new())
                            {
                                <option value="@cat.Value"
                                        selected="@(ViewBag.CategoryId
                                                                                                                            ?.ToString() == cat.Value)">
                                @cat.Text
                            </option>
                                                        }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <button type="submit"
                                class="btn btn-primary w-100">
                            <i class="bi bi-funnel me-1"></i>
                            Apply Filter
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Books Grid -->
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-book-x text-muted"
               style="font-size:4rem"></i>
            <h4 class="mt-3 text-muted">No books found</h4>
            <p class="text-muted">
                Try a different search or filter.
            </p>
            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Books"
                   asp-action="Create"
                   class="btn btn-primary mt-2">
                    <i class="bi bi-plus-lg me-1"></i>
                    Add First Book
                </a>
            }
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3
                            row-cols-xl-4 g-4">
            @foreach (var book in Model)
            {
                <div class="col">
                    <div class="card book-card h-100">

                        <!-- Cover Image -->
                        @if (!string.IsNullOrEmpty(book.CoverImagePath))
                        {
                            <img src="@book.CoverImagePath"
                                 class="book-cover"
                                 alt="@book.Title" />
                        }
                        else
                        {
                            <div class="book-cover-placeholder">
                                <i class="bi bi-book"></i>
                            </div>
                        }

                        <div class="card-body d-flex flex-column">
                            <h6 class="card-title fw-bold mb-1">
                                @book.Title
                            </h6>
                            <p class="text-muted small mb-2">
                                <i class="bi bi-person me-1"></i>
                                @book.Author
                            </p>

                            <!-- Categories -->
                            <div class="mb-2">
                                @foreach (var bc in book.BookCategories)
                                {
                                    <span class="badge bg-light
                                                                         text-dark border me-1">
                                        @bc.Category?.Name
                                    </span>
                                }
                            </div>

                            <!-- Availability -->
                            @if (book.AvailableCopies > 0)
                            {
                                <div class="availability-bar
                                                                    available mb-2">
                                    <i class="bi bi-check-circle me-1"></i>
                                    @book.AvailableCopies Available
                                </div>
                            }
                            else
                            {
                                <div class="availability-bar
                                                                    unavailable mb-2">
                                    <i class="bi bi-x-circle me-1"></i>
                                    Not Available
                                </div>
                            }

                            <!-- Action Buttons -->
                            <div class="mt-auto d-flex gap-2">
                                <a asp-controller="Books"
                                   asp-action="Details"
                                   asp-route-id="@book.Id"
                                   class="btn btn-outline-primary
                                                          btn-sm flex-grow-1">
                                    <i class="bi bi-eye me-1"></i>
                                    Details
                                </a>
                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-controller="Books"
                                       asp-action="Edit"
                                       asp-route-id="@book.Id"
                                       class="btn btn-outline-warning
                                                                      btn-sm">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-controller="Books"
                                       asp-action="Delete"
                                       asp-route-id="@book.Id"
                                       class="btn btn-outline-danger
                                                                      btn-sm">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>