@model IEnumerable<LibraryManagementSystem.Models.Fine>
@{
    ViewData["Title"] = "Manage Fines";
    decimal totalUnpaid = Model.Where(f => !f.IsPaid)
        .Sum(f => f.Amount);
    decimal totalPaid = Model.Where(f => f.IsPaid)
        .Sum(f => f.Amount);
}

<div class="container-fluid mt-4 px-4">
    <div class="page-header mb-4">
        <h2 class="fw-bold mb-0">
            <i class="bi bi-cash me-2"></i> Manage Fines
        </h2>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card stat-card stat-card-danger text-center p-3">
                <h3 class="fw-bold text-danger mb-0">
                    $@totalUnpaid.ToString("F2")
                </h3>
                <small class="text-muted">Total Unpaid</small>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card stat-card-success text-center p-3">
                <h3 class="fw-bold text-success mb-0">
                    $@totalPaid.ToString("F2")
                </h3>
                <small class="text-muted">Total Collected</small>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card stat-card-primary text-center p-3">
                <h3 class="fw-bold mb-0">@Model.Count()</h3>
                <small class="text-muted">Total Records</small>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-cash text-muted"
                       style="font-size:3rem"></i>
                    <h5 class="mt-3 text-muted">No fines recorded</h5>
                </div>
            }
            else
            {
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Member</th>
                            <th>Book</th>
                            <th>Amount</th>
                            <th>Reason</th>
                            <th>Issued On</th>
                            <th>Status</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var fine in Model)
                        {
                            <tr>
                                <td>
                                    <strong>
                                        @fine.BorrowRecord?.User?.FullName
                                    </strong>
                                    <br />
                                    <small class="text-muted">
                                        @fine.BorrowRecord?.User?.Email
                                    </small>
                                </td>
                                <td>
                                    @fine.BorrowRecord?.Book?.Title
                                </td>
                                <td>
                                    <strong class="text-danger">
                                        $@fine.Amount.ToString("F2")
                                    </strong>
                                </td>
                                <td>
                                    <small>@fine.Reason</small>
                                </td>
                                <td>
                                    @fine.IssuedDate
                                    .ToString("MMM dd, yyyy")
                                </td>
                                <td>
                                    @if (fine.IsPaid)
                                    {
                                        <span class="badge bg-success">
                                            Paid
                                        </span>
                                        <br />
                                        <small class="text-muted">
                                            @fine.PaidDate?
                                            .ToString("MMM dd, yyyy")
                                        </small>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">
                                            Unpaid
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (!fine.IsPaid)
                                    {
                                        <form asp-action="MarkPaid"
                                              asp-route-id="@fine.Id"
                                              method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit"
                                                    class="btn btn-sm
                                                                                   btn-success">
                                                <i class="bi bi-check-lg
                                                                                   me-1"></i>
                                                Mark Paid
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">
                                            Settled
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>