@model LibraryManagementSystem.Models.LibraryProfile
@{
    ViewData["Title"] = "Library Profile";
}

<div class="container mt-4">
    <div class="page-header mb-4">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 class="fw-bold mb-0">
                    <i class="bi bi-building me-2"></i> Library Profile
                </h2>
                <p class="mb-0 mt-1 opacity-75">
                    About our library
                </p>
            </div>
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Edit"
                   class="btn btn-warning fw-semibold">
                    <i class="bi bi-pencil me-1"></i> Edit Profile
                </a>
            }
        </div>
    </div>

    @if (Model == null)
    {
        <div class="card text-center py-5">
            <div class="card-body">
                <i class="bi bi-building text-muted"
                   style="font-size:4rem"></i>
                <h4 class="mt-3 text-muted">
                    No library profile set up yet
                </h4>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Edit"
                       class="btn btn-primary mt-3">
                        <i class="bi bi-plus-lg me-1"></i>
                        Set Up Library Profile
                    </a>
                }
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            <!-- Main Info Card -->
            <div class="col-lg-8">
                <div class="card h-100">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-info-circle me-2"></i>
                            Library Information
                        </h5>
                    </div>
                    <div class="card-body p-4">
                        <h2 class="fw-bold text-primary mb-3">
                            @Model.LibraryName
                        </h2>

                        @if (!string.IsNullOrEmpty(Model.Description))
                        {
                            <p class="text-muted lh-lg mb-4">
                                @Model.Description
                            </p>
                        }

                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="d-flex align-items-start gap-3">
                                    <div class="profile-icon bg-primary-subtle
                                                        rounded p-2">
                                        <i class="bi bi-geo-alt text-primary
                                                          fs-5"></i>
                                    </div>
                                    <div>
                                        <p class="fw-semibold mb-0">Location</p>
                                        <p class="text-muted mb-0">
                                            @Model.Location
                                        </p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="d-flex align-items-start gap-3">
                                    <div class="profile-icon bg-success-subtle
                                                        rounded p-2">
                                        <i class="bi bi-clock text-success
                                                          fs-5"></i>
                                    </div>
                                    <div>
                                        <p class="fw-semibold mb-0">
                                            Operating Hours
                                        </p>
                                        <p class="text-muted mb-0">
                                            @Model.OperatingHours
                                        </p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="d-flex align-items-start gap-3">
                                    <div class="profile-icon bg-info-subtle
                                                        rounded p-2">
                                        <i class="bi bi-telephone text-info
                                                          fs-5"></i>
                                    </div>
                                    <div>
                                        <p class="fw-semibold mb-0">
                                            Phone
                                        </p>
                                        <p class="text-muted mb-0">
                                            @Model.ContactNumber
                                        </p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="d-flex align-items-start gap-3">
                                    <div class="profile-icon bg-warning-subtle
                                                        rounded p-2">
                                        <i class="bi bi-envelope text-warning
                                                          fs-5"></i>
                                    </div>
                                    <div>
                                        <p class="fw-semibold mb-0">Email</p>
                                        <p class="text-muted mb-0">
                                            @Model.ContactEmail
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Side Stats Card -->
            <div class="col-lg-4">
                <div class="card h-100">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-bar-chart me-2"></i>
                            Quick Stats
                        </h5>
                    </div>
                    <div class="card-body">
                        @if (Model.EstablishedYear.HasValue)
                        {
                            <div class="text-center mb-4">
                                <h1 class="display-4 fw-bold text-primary">
                                    @Model.EstablishedYear
                                </h1>
                                <p class="text-muted">Year Established</p>
                            </div>
                            <hr />
                        }
                        <div class="text-center">
                            <i class="bi bi-book text-primary"
                               style="font-size:3rem"></i>
                            <p class="mt-2 text-muted">
                                Your trusted community library
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>