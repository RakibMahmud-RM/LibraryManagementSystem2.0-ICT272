@model LibraryManagementSystem.Models.LibraryProfile
@{
    ViewData["Title"] = "Edit Library Profile";
}

<div class="container mt-4">
    <div class="page-header mb-4">
        <h2 class="fw-bold mb-0">
            <i class="bi bi-building-gear me-2"></i>
            Edit Library Profile
        </h2>
        <p class="mb-0 mt-1 opacity-75">
            Update your library information
        </p>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="All"
                             class="alert alert-danger"></div>

                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="LibraryName"
                                   class="form-label fw-semibold"></label>
                            <input asp-for="LibraryName"
                                   class="form-control"
                                   placeholder="e.g. City Central Library" />
                            <span asp-validation-for="LibraryName"
                                  class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Location"
                                   class="form-label fw-semibold"></label>
                            <input asp-for="Location"
                                   class="form-control"
                                   placeholder="Full address" />
                            <span asp-validation-for="Location"
                                  class="text-danger small"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="OperatingHours"
                                       class="form-label fw-semibold"></label>
                                <input asp-for="OperatingHours"
                                       class="form-control"
                                       placeholder="e.g. Mon-Fri 9am-6pm" />
                                <span asp-validation-for="OperatingHours"
                                      class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="EstablishedYear"
                                       class="form-label fw-semibold"></label>
                                <input asp-for="EstablishedYear"
                                       class="form-control"
                                       type="number"
                                       placeholder="e.g. 1995" />
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="ContactNumber"
                                       class="form-label fw-semibold"></label>
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="bi bi-telephone"></i>
                                    </span>
                                    <input asp-for="ContactNumber"
                                           class="form-control"
                                           placeholder="Phone number" />
                                </div>
                                <span asp-validation-for="ContactNumber"
                                      class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ContactEmail"
                                       class="form-label fw-semibold"></label>
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="bi bi-envelope"></i>
                                    </span>
                                    <input asp-for="ContactEmail"
                                           class="form-control"
                                           placeholder="email@library.com" />
                                </div>
                                <span asp-validation-for="ContactEmail"
                                      class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description"
                                   class="form-label fw-semibold"></label>
                            <textarea asp-for="Description"
                                      class="form-control"
                                      rows="4"
                                      placeholder="Brief description about the library..."></textarea>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit"
                                    class="btn btn-primary px-4">
                                <i class="bi bi-check-lg me-1"></i>
                                Save Profile
                            </button>
                            <a asp-action="Index"
                               class="btn btn-outline-secondary px-4">
                                <i class="bi bi-x-lg me-1"></i>
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}